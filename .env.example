# ==========================================
# 象长老 — 环境变量配置
# 复制此文件为 .env.local 并填入真实值
# .env.local 不会被提交到 GitHub
# ==========================================

# --- Phase 1a: 核心对话 MVP ---

# Claude API（象长老对话引擎）
ANTHROPIC_API_KEY=

# 火山引擎 TTS（象长老的声音）
VOLCENGINE_TTS_APP_ID=
VOLCENGINE_TTS_ACCESS_TOKEN=
VOLCENGINE_TTS_CLUSTER=volcano_tts
VOLCENGINE_TTS_VOICE_TYPE=BV700_streaming
VOLCENGINE_TTS_SPEED_RATIO=0.86
VOLCENGINE_TTS_PITCH_RATIO=0.92

# TTS 设置
TTS_PROVIDER=volcengine
TTS_DEMO_MODE=1

# --- Phase 1b: 音乐生成 ---

# MiniMax（Music 2.6 + 备选 TTS）
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=

# --- Phase 2: 用户体系 ---

# Neon 数据库
DATABASE_URL=

# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Cloudflare R2 云存储
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# --- Phase 3: 通知 + 安全 ---

# Cloudflare Turnstile 人机验证
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Resend 邮件服务
RESEND_API_KEY=
